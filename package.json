{
    "name": "odh-ide-extensions",
    "version": "0.0.0",
    "description": "Open Data Hub IDE Extensions",
    "private": true,
    "license": "Apache-2.0",
    "packageManager": "npm@10.9.2",
    "workspaces": [
        "odh-jupyter-trash-cleanup"
    ],
    "scripts": {
        "build": "turbo run build",
        "lint": "turbo run lint",
        "test": "turbo run test",
        "build:prod": "turbo run build:prod",
        "eslint": "eslint . --fix --ignore-path .gitignore --ext .ts,.tsx,.js",
        "eslint:check": "eslint . --ignore-path .gitignore --ext .ts,.tsx,.js",
        "prettier": "prettier --ignore-path .gitignore --write \"**/*{.ts,.tsx,.js,.jsx,.css,.json}\"",
        "prettier:check": "prettier --ignore-path .gitignore --check \"**/*{.ts,.tsx,.js,.jsx,.css,.json}\""
    },
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "~6.13.2",
        "@typescript-eslint/parser": "~6.13.2",
        "dotenv": "^16.4.7",
        "dotenv-expand": "^5.1.0",
        "eslint": "~8.55.0",
        "eslint-config-prettier": "~9.1.0",
        "eslint-plugin-cypress": "^4.1.0",
        "eslint-plugin-header": "^3.1.1",
        "eslint-plugin-import": "^2.29.1",
        "eslint-plugin-react": "~7.33.2",
        "eslint-plugin-react-hooks": "^4.6.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.1.2",
        "npm-run-all": "^4.1.5",
        "prettier": "^3.6.2",
        "stylelint": "^16.0.0",
        "stylelint-config-standard": "^36.0.0",
        "turbo": "^2.4.2",
        "typescript": "~5.5.4"
    }
}
